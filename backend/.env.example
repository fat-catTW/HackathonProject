# Copy this file to `backend/.env` or the project root `.env`.

USE_MOCK=true

AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_PROFILE=

BEDROCK_MODEL_ID=apac.amazon.nova-pro-v1:0
DYNAMODB_TABLE_NAME=ServiceAssistant
ALLOW_DEMO_AUTH=true
AGENT_TOOL_MODE=embedded

LIST_SERVICES_LAMBDA_NAME=
GET_SERVICE_SCHEMA_LAMBDA_NAME=
SUBMIT_SERVICE_REQUEST_LAMBDA_NAME=

COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

AGENTCORE_RUNTIME_ARN=
AGENTCORE_MEMORY_ID=
AGENTCORE_GATEWAY_URL=
AGENTCORE_GATEWAY_MCP_PATH=/mcp
AGENTCORE_GATEWAY_AUTH_SCHEME=Bearer
AGENTCORE_GATEWAY_AUTH_TOKEN=
MCP_LIST_SERVICES_TOOL_NAME=list_services
MCP_GET_SERVICE_SCHEMA_TOOL_NAME=get_service_schema
MCP_SUBMIT_SERVICE_REQUEST_TOOL_NAME=submit_service_request
