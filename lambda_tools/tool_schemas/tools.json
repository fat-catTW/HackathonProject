[
  {
    "name": "list_services",
    "description": "取得目前可使用的生活服務列表",
    "inputSchema": {"type": "object", "properties": {}, "required": []}
  },
  {
    "name": "get_service_schema",
    "description": "取得指定服務所需的表單欄位定義",
    "inputSchema": {
      "type": "object",
      "properties": {
        "service_id": {"type": "string", "description": "服務 ID，例如 air_conditioner_cleaning"}
      },
      "required": ["service_id"]
    }
  },
  {
    "name": "submit_service_request",
    "description": "驗證表單並建立正式服務案件。呼叫前必須先取得使用者明確確認。",
    "inputSchema": {
      "type": "object",
      "properties": {
        "service_id": {"type": "string"},
        "session_id": {"type": "string"},
        "payload": {"type": "object", "description": "表單欄位鍵值，需符合 get_service_schema 回傳的欄位"}
      },
      "required": ["service_id", "session_id", "payload"]
    }
  }
]
